# Application
APP_ENV=production
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite+aiosqlite:///./data/assets.db

# Server
HOST=0.0.0.0
PORT=8000

# AWS (no hardcoded credentials — use IAM role or aws-profile)
AWS_PROFILE=my-asset-project
AWS_DEFAULT_REGION=eu-west-2
S3_BACKUP_BUCKET=your-backup-bucket-name
