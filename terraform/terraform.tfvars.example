# Windows: if provider install fails with "file is being used by another process",
# run commands via:  .\tf.ps1 init   .\tf.ps1 plan   .\tf.ps1 apply
# (optional: $env:TERRAFORM_EXE = 'd:\path\to\terraform.exe')
#
# AWS credentials (pick one):
#   - aws configure   # uses [default] profile
#   - $env:AWS_PROFILE = "your-profile"   # needs matching [your-profile] in %USERPROFILE%\.aws\credentials
#
# Copy to terraform.tfvars (gitignored) and adjust.
# aws_region    = "ap-south-1"
# s3_bucket_name = "asset-register-backup-bigb787-global-unique"

# Place your public key next to main.tf as asset-register.pub (see public_key_file).
